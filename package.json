{
  "name": "ai-knowledge-site",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "NEXT_TRACE_UPLOAD_DISABLED=1 next build",
    "build:local": "node scripts/generate-data.mjs && next build",
    "start": "next start -p 8000",
    "test": "node node_modules/vitest/vitest.mjs run",
    "test:watch": "node node_modules/vitest/vitest.mjs",
    "deploy": "npm run build:local && rsync -avz --delete --exclude='node_modules' --exclude='.next/cache' ./ root@kb.ccbot.chat:/www/wwwroot/kb.ccbot.chat/ && ssh root@kb.ccbot.chat 'cd /www/wwwroot/kb.ccbot.chat && npm i --production && pm2 restart ai-knowledge || pm2 start ecosystem.config.js'"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "gray-matter": "^4.0.3",
    "minisearch": "^7.0.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
